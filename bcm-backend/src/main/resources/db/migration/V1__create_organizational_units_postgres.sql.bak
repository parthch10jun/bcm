-- =====================================================
-- BCM Platform - Database Migration V1
-- Create Organizational Units Table (Self-Referencing Hierarchy)
-- =====================================================

-- Create organizational_units table
CREATE TABLE organizational_units (
    id BIGSERIAL PRIMARY KEY,
    
    -- Basic Information
    unit_code VARCHAR(50) UNIQUE,
    unit_name VARCHAR(255) NOT NULL,
    description TEXT,
    
    -- Self-Referencing Hierarchy
    parent_unit_id BIGINT,
    
    -- Unit Classification
    unit_type VARCHAR(50) NOT NULL,
    is_bia_eligible BOOLEAN NOT NULL DEFAULT false,
    
    -- Unit Leadership
    unit_head VARCHAR(255),
    unit_head_email VARCHAR(255),
    unit_head_phone VARCHAR(50),
    
    -- Location Reference (will be created in later migration)
    location_id BIGINT,
    
    -- Criticality Information
    criticality_tier VARCHAR(20),
    criticality_score INTEGER,
    
    -- Organizational Metrics
    employee_count INTEGER,
    annual_budget DECIMAL(15, 2),
    
    -- Flexible Metadata
    metadata TEXT,
    
    -- Audit Fields
    created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP,
    created_by VARCHAR(255),
    updated_by VARCHAR(255),
    version BIGINT DEFAULT 0,
    is_deleted BOOLEAN DEFAULT false,
    
    -- Foreign Key Constraints
    CONSTRAINT fk_parent_unit FOREIGN KEY (parent_unit_id) 
        REFERENCES organizational_units(id) ON DELETE CASCADE,
    
    -- Check Constraints
    CONSTRAINT chk_unit_type CHECK (unit_type IN (
        'ORGANIZATION', 'DIVISION', 'DEPARTMENT', 'TEAM', 'SUB_TEAM', 'CUSTOM'
    )),
    CONSTRAINT chk_criticality_tier CHECK (criticality_tier IN (
        'TIER_1', 'TIER_2', 'TIER_3', 'TIER_4', 'TIER_5'
    ))
);

-- Create Indexes for Performance
CREATE INDEX idx_parent_unit ON organizational_units(parent_unit_id);
CREATE INDEX idx_unit_type ON organizational_units(unit_type);
CREATE INDEX idx_bia_eligible ON organizational_units(is_bia_eligible);
CREATE INDEX idx_unit_code ON organizational_units(unit_code);
CREATE INDEX idx_unit_name ON organizational_units(unit_name);
CREATE INDEX idx_is_deleted ON organizational_units(is_deleted);

-- Create Index for BIA-Eligible Units (Most Common Query)
CREATE INDEX idx_bia_eligible_units ON organizational_units(is_bia_eligible, is_deleted) 
    WHERE is_bia_eligible = true AND is_deleted = false;

-- Comments for Documentation
COMMENT ON TABLE organizational_units IS 'Self-referencing hierarchical organizational structure supporting unlimited nesting levels';
COMMENT ON COLUMN organizational_units.parent_unit_id IS 'Self-referencing foreign key - NULL for top-level organization';
COMMENT ON COLUMN organizational_units.is_bia_eligible IS 'Flag indicating if BIAs can be conducted for this unit (typically leaf nodes)';
COMMENT ON COLUMN organizational_units.unit_type IS 'Type of organizational unit (ORGANIZATION, DIVISION, DEPARTMENT, TEAM, etc.)';
COMMENT ON COLUMN organizational_units.metadata IS 'JSON format for flexible additional data';

